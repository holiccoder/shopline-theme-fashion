            "main-collection-products__card__info": {
              "type": "product-card/_info",
              "blocks": {
                "main-collection-products__card__info__title": {
                  "type": "product-title"
                },
                "main-collection-products__card__info__price": {
                  "type": "product-price"
                },
                "main-collection-products__card__info__description": {
                  "type": "product-card/_description"
                },
                "main-collection-products__card__info__buy-button": {
                  "type": "product-buy-button"
                }
              },
              "block_order": [
                "main-collection-products__card__info__title",
                "main-collection-products__card__info__price",
                "main-collection-products__card__info__description",
                "main-collection-products__card__info__buy-button"
              ]
            }
          },
          "block_order": [
            "main-collection-products__card__image",
            "main-collection-products__card__info"
          ]
